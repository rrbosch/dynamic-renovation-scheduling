# ---- Generated experiment outputs (regenerable from instances + configs + seeds) ----
results/
scratch/
hpc log/
hpc_log/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg

# ---- Virtual environments ----
# NOTE: do NOT add a bare `ENV/` here — with core.ignorecase=true (Windows/macOS)
# it also matches the source package `env/` and silently untracks core code.
.venv/
venv/
env_venv/
.env

# ---- Testing / coverage ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ---- Notebooks ----
.ipynb_checkpoints/

# ---- IDE / editor ----
.idea/
.claude/settings.local.json
.vscode/
*.swp
*~

# ---- OS cruft ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Model / run artifacts (large, regenerable) ----
*.pkl
*.pt
*.pth
*.ckpt
checkpoints/
wandb/

# ---- LaTeX build artifacts (keep .tex source) ----
*.aux
*.bbl
*.blg
*.log
*.out
*.synctex.gz
*.toc
*.fls
*.fdb_latexmk
