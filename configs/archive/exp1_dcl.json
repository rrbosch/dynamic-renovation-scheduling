{
  "network": "sioux_falls",
  "tap_backend": "fast",
  "seed": 42,
  "run_name": "exp_simple_dcl_1step_rollout",
  "instance": "instances/instance_002.json",
  "training": {
    "time_budget": 86400,
    "n_episodes": 5000,
    "eval_interval": 500,
    "n_eval_episodes": 10,
    "update_interval": 50,
    "buffer_capacity": 200000,
    "buffer_strategy": "fifo",
    "truncation_mode": "bootstrap"
  },
  "agent": {
    "agent_type": "dcl",
    "extra": {
      "policy_type": "xgboost",
      "value_fn": "xgboost",
      "finite_horizon": true,
      "action_gen": "local_search",
      "rollout_horizon": 1,
      "n_rollouts": 5,
      "min_samples_train": 50000,
      "use_global_context": true,
      "heuristic_policy": {
        "agent_type": "reactive",
        "extra": {"threshold": 0.8}
      }
    }
  }
}
