{
  "network": "sioux_falls",
  "tap_backend": "fast",
  "seed": 42,
  "run_name": "exp0/i10p_adp_normal_policy_lowesterror_xgb",
  "instance": "instances/instance_10p.json",
  "training": {
    "time_budget": 86400,
    "eval_interval": 1000000,
    "eval_interval_seconds": 3600,
    "update_interval": 50,
    "truncation_mode": "horizon_rollout",
    "buffer_capacity": 200000,
    "buffer_strategy": "lowest_error",
    "n_eval_episodes": 10,
    "n_workers": 16,
    "n_warmstart_episodes": 1667,
    "warmstart": {
      "agent_type": "reactive",
      "extra": {
        "threshold": 0.95
      }
    }
  },
  "agent": {
    "agent_type": "adp",
    "value_fn": "xgboost",
    "action_gen": "local_search"
  }
}
